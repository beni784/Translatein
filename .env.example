# ============================================================
# LinguaLoom AI - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local to source control.
# ------------------------------------------------------------

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default model
# Recommended (per May 2026):
#   - gemini-2.5-flash       → fast + cheap (default)
#   - gemini-2.5-flash-lite  → lebih murah, cukup untuk terjemahan sederhana
#   - gemini-2.5-pro         → kualitas paling tinggi (lebih lambat & mahal)
# Note: gemini-1.5-flash sudah di-deprecate oleh Google.
GEMINI_MODEL=gemini-2.5-flash

# Optional: branding
NEXT_PUBLIC_APP_NAME=LinguaLoom AI
