# ============================================================
# LinguaLoom AI - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local to source control.
# ------------------------------------------------------------

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default model
# Recommended: gemini-1.5-flash (fast + cheap) or gemini-1.5-pro (higher quality)
GEMINI_MODEL=gemini-1.5-flash

# Optional: branding
NEXT_PUBLIC_APP_NAME=LinguaLoom AI
